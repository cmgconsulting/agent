# ============================================
# CMG Agents — Environment Variables
# Copy this file to .env.local and fill in values
# ============================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (Claude API)
ANTHROPIC_API_KEY=sk-ant-...

# Encryption (generate: openssl rand -hex 32)
ENCRYPTION_KEY=your-256bit-hex-key

# App URL (used for CORS, OAuth callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Make.com webhook secret
MAKE_WEBHOOK_SECRET=your-webhook-secret

# Google OAuth (for Gmail connector)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Meta/Facebook (for Eva social agent)
# META_APP_ID=
# META_APP_SECRET=
# META_PAGE_ACCESS_TOKEN=

# WhatsApp Business (for Ludo SAV agent)
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_VERIFY_TOKEN=

# Twilio (for SMS via Ludo)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# Pennylane (for Leo ops agent)
# PENNYLANE_API_KEY=

# Airtable (for CRM/tickets)
# AIRTABLE_API_KEY=
# AIRTABLE_BASE_ID=
